---
interface Props {
	title?: string;
	description?: string;
	/** Set when the page markup provides its own data-barba container (e.g. project
	    pages). Nesting two containers makes Barba grab the outer "default" one, so
	    namespace checks (isProject, views) silently break. */
	ownBarbaContainer?: boolean;
}

const { title = "DT —— Motion Designer", description = "Portfolio of Daniel Tolani - Motion & Interaction Designer", ownBarbaContainer = false } = Astro.props;

import PageTransition from '../components/PageTransition.astro';
import BarbaTransition from '../components/BarbaTransition.astro';
import BackgroundMusic from '../components/BackgroundMusic.astro';
import Header from '../components/Header.astro';

// Get the site URL from environment or construct from request
const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME;
const metaImage = `https://res.cloudinary.com/${cloudName}/image/upload/f_auto,q_auto/META-IMAGE_qlrqtf.png`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<!-- Runs before first paint: marks that JS is on, so the page-enter pre-hide
		     only applies when JS can reveal it (no-JS users always see content). -->
		<script is:inline>document.documentElement.classList.add('js-enter');</script>

		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url.href} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={metaImage} />

		<!-- X (Twitter) -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url.href} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={metaImage} />
    
		<link rel="stylesheet" href="/font/stylesheet.css">
	</head>
	<body data-barba="wrapper">
    <Header />
    <PageTransition />
    {ownBarbaContainer ? (
      <slot />
    ) : (
      <div data-barba="container" data-barba-namespace="default">
        <slot />
      </div>
    )}
    <BarbaTransition />
    <BackgroundMusic />
	</body>
</html>

<style is:global>
	*, *::before, *::after {
		box-sizing: border-box;
	}

	/* No visible scrollbars anywhere — scrolling is custom/virtual and the
	   home page shows progress in the SCRL readout instead. */
	* {
		scrollbar-width: none;
		-ms-overflow-style: none;
	}
	*::-webkit-scrollbar {
		display: none;
		width: 0;
		height: 0;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		width: 100%;
		height: 100%;
		overflow-x: hidden;
	}

	body {
		font-family: 'Suisse Int\'l', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
		/* Static dark underlay so the page-enter slide reveals no gap — only the
		   content reads as moving, the (matching) background stays put. */
		background-color: #141417;
	}

	/* Hide the page until the staggered entrance starts, so the first paint isn't
	   the rest state (which caused a flicker on refresh). staggerEnter() reveals it.
	   Scoped to the home (default) namespace only — project pages run their own
	   ScrollTrigger intro and are masked by the red cover, so they must not be
	   pre-hidden (otherwise they can get stuck invisible). */
	html.js-enter [data-barba="container"][data-barba-namespace="default"] {
		opacity: 0;
	}
</style>
