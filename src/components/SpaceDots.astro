---
// 3D drifting dot field (same family as the projects starfield): tiny mosaic
// squares in z-space, slowly drifting toward the camera with a soft mouse
// parallax. Position it inside any relatively-positioned dark section; content
// above it needs position:relative + z-index. Multi-instance safe; re-inits
// per Barba visit and each raf self-terminates when its page is swapped out.
interface Props {
  /** Height of the field (e.g. "72vh" for the home hero's black space). */
  height?: string;
}
const { height = "100%" } = Astro.props;
---

<div class="space-dots" aria-hidden="true" style={`height:${height};`}></div>

<style is:global>
  .space-dots {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    overflow: hidden;
    perspective: 900px;
    pointer-events: none;
    z-index: 0;
  }
  .space-dots-world {
    position: absolute;
    inset: 0;
    transform-style: preserve-3d;
  }
  .space-dot {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 3px;
    height: 3px;
    opacity: 0;
  }
</style>

<script>
  const DOTS = {
    count: 80,
    depth: 2600,            // px of looping z-space
    drift: 0.55,            // px of camera travel per frame
    maxAlpha: 0.8,
    colors: ["#f72f2f", "#e5eaf4", "#5a5b5e"],
  };

  // One shared mouse tracker for every field on the site.
  const dotsMouse = { x: 0, y: 0 };
  window.addEventListener("mousemove", (e) => {
    dotsMouse.x = (e.clientX / window.innerWidth - 0.5) * 2;
    dotsMouse.y = (e.clientY / window.innerHeight - 0.5) * 2;
  });

  function initDots(holder: HTMLElement) {
    const world = document.createElement("div");
    world.className = "space-dots-world";
    holder.appendChild(world);

    const dots = Array.from({ length: DOTS.count }, () => {
      const el = document.createElement("div");
      el.className = "space-dot";
      el.style.background = DOTS.colors[Math.floor(Math.random() * DOTS.colors.length)];
      world.appendChild(el);
      return {
        el,
        x: (Math.random() - 0.5) * window.innerWidth * 1.6,
        y: (Math.random() - 0.5) * Math.max(holder.offsetHeight, 400) * 1.6,
        z: -Math.random() * DOTS.depth,
      };
    });

    let cam = 0;
    function raf() {
      if (!world.isConnected) return;
      cam += DOTS.drift;
      world.style.transform = `rotateX(${dotsMouse.y * 2.5}deg) rotateY(${dotsMouse.x * 2.5}deg)`;
      for (const s of dots) {
        // Loop z into [-depth+250, 250): far dots fade in, near dots fade out.
        const z = ((((s.z + cam) % DOTS.depth) + DOTS.depth) % DOTS.depth) - DOTS.depth + 250;
        let a = (z + DOTS.depth - 250) / 500;
        if (z > 80) a = Math.min(a, 1 - (z - 80) / 170);
        a = Math.max(0, Math.min(a, DOTS.maxAlpha));
        s.el.style.opacity = a.toFixed(3);
        s.el.style.transform = `translate(-50%, -50%) translate3d(${s.x}px, ${s.y}px, ${z}px)`;
      }
      requestAnimationFrame(raf);
    }
    requestAnimationFrame(raf);
  }

  function initAllDots() {
    document.querySelectorAll<HTMLElement>(".space-dots").forEach((holder) => {
      if (holder.dataset.bound) return;
      holder.dataset.bound = "true";
      initDots(holder);
    });
  }

  initAllDots();
  document.addEventListener("astro:page-load", initAllDots);
</script>
