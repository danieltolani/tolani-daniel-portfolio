---
// Header component for all pages
const currentPath = Astro.url.pathname;
const isProjectPage = currentPath.startsWith('/projects/');
const isHomePage = currentPath === '/';

// Nav indicator: a red tile grid behind each link, built with the SAME effect as
// the "Enter with sound" button. Inactive links show NOTHING at rest; the ACTIVE
// link shows a partial (~50%) indicator that doesn't cover the text. Hover builds
// every tile up left->right with a sprinkle of white, and draws back out on exit.
const NAV_COLS = 8;
const NAV_ROWS = 2;
const NAV_FILL = 0.5;
const navMaxOrder = NAV_COLS - 1;
const navCells = Array.from({ length: NAV_COLS * NAV_ROWS }, (_, i) => {
  const c = i % NAV_COLS;
  const r = Math.floor(i / NAV_COLS);
  const order = c;                                    // left -> right wave
  const jitter = (((c * 13 + r * 7) % 5) - 2) * 0.05; // ±0.10 ragged edge
  const on = order / navMaxOrder <= NAV_FILL + jitter; // ACTIVE link's resting indicator
  const white = Math.random() < 0.4;                  // sprinkle of white on build-up
  const scatter = Math.floor(Math.random() * 3);      // 0/1/2 frame stop-motion scatter
  return { order, on, white, scatter };
});
const navFmax = Math.max(...navCells.map((c) => c.order + c.scatter));
const navItems = [
  { href: '/projects', label: 'PRJT.WORK' },
  { href: '/about', label: 'AB.ME' },
  { href: '/contact', label: 'CT.MAIL' },
];

// Mobile menu background: a full-screen mosaic that BUILDS DOWN (top row first) to form
// the dark overlay when the menu opens, with a sprinkle of tiles flashing white. Tiles
// are 1fr cells stretched over the panel; order is by row so the wave rolls downward.
const MENU_COLS = 8;
const MENU_ROWS = 14;
const menuTiles = Array.from({ length: MENU_COLS * MENU_ROWS }, (_, i) => {
  const order = Math.floor(i / MENU_COLS);          // row index -> build downward
  const scatter = Math.floor(Math.random() * 3);    // 0/1/2 frame stop-motion scatter
  const white = Math.random() < 0.14;               // sprinkle that flashes white
  return { order, scatter, white };
});
---

<header class="header" id="main-header" data-barba-prevent="all">
	<a href="/" class={`header-logo ${isHomePage ? 'active' : ''}`}>
        <svg xmlns="http://www.w3.org/2000/svg" width="73" height="60" fill="none"><path fill="#F72F2F" d="M30.732 10v39.295h-8.943v-3.902c-.904 1.518-2.187 2.674-3.849 3.469C16.278 49.62 14.58 50 12.845 50c-3.794 0-6.883-1.373-9.268-4.12C1.192 43.136 0 39.414 0 34.716c0-4.697 1.192-8.4 3.577-11.11 2.385-2.747 5.474-4.12 9.268-4.12 1.735 0 3.433.398 5.095 1.192 1.662.76 2.945 1.898 3.849 3.415V10h8.943Zm-19.62 18.645c-1.23 1.445-1.844 3.469-1.844 6.07 0 2.602.615 4.644 1.843 6.125 1.229 1.482 2.782 2.222 4.661 2.222 1.915 0 3.47-.668 4.662-2.005 1.192-1.373 1.788-3.487 1.788-6.342 0-2.854-.596-4.95-1.788-6.287-1.193-1.337-2.747-2.005-4.662-2.005-1.879 0-3.432.74-4.66 2.222Z"/><path fill="#F72F2F" d="M30.732 18.13H22.84V10h29.843v8.13H40.054v31.165h-9.322V18.13ZM48.888 49.295v-9.647H58.97v9.647H48.89Z"/><path fill="#F72F2F" d="M52.803 49.295v-9.647h10.081v9.647H52.803Z"/></svg>
	</a>
	<nav class="nav">
		{navItems.map((item) => (
			<a href={item.href} class={currentPath.startsWith(item.href) ? 'active' : ''}>
				<span class="nav-mosaic" aria-hidden="true" style={`--cols:${NAV_COLS};--rows:${NAV_ROWS};--fmax:${navFmax}`}>
					{navCells.map((cell) => (
						<i class:list={["nav-tile", { "is-on": cell.on, "is-white": cell.white }]} style={`--o:${cell.order};--s:${cell.scatter}`}></i>
					))}
				</span>
				{item.label}
			</a>
		))}
	</nav>

	<!-- Mobile menu trigger (≤768px): a red-block glyph in the audio-visualizer family,
	     plus a "see.pages" label. Toggles the panel below. -->
	<button class="nav-menu-btn" id="nav-menu-btn" type="button" aria-expanded="false" aria-controls="nav-menu-panel" aria-label="Open menu">
		<span class="nav-menu-icon" aria-hidden="true">
			<i class="nmi-a"></i><i class="nmi-b"></i><i class="nmi-c"></i>
			<i class="nmi-d"></i><i class="nmi-e"></i>
			<i class="nmi-f"></i>
		</span>
	</button>
</header>

<!-- Mobile menu panel — full-screen. OUTSIDE the header so it isn't inverted by the
     header's mix-blend-mode: difference, and BELOW it (z-index) so the X close button
     stays on top. data-barba-prevent="all" keeps these links on the SAME custom
     navigation path as the desktop nav (barba.go), so a tap never hard-reloads into
     the red enter-gate. -->
<nav class="nav-menu-panel" id="nav-menu-panel" aria-label="Pages" data-barba-prevent="all">
	<span class="nav-menu-mosaic" aria-hidden="true" style={`--cols:${MENU_COLS};--rows:${MENU_ROWS}`}>
		{menuTiles.map((t) => (
			<i class:list={["nmm-tile", { "nmm-white": t.white }]} style={`--o:${t.order};--s:${t.scatter}`}></i>
		))}
	</span>
	{navItems.map((item) => (
		<a href={item.href} class:list={["nav-menu-link", { active: currentPath.startsWith(item.href) }]}>{item.label}</a>
	))}
</nav>

<script>
  // Scrollspy for the home page's #projects section: PRJT.WORK stays
  // unhighlighted while scrolling the hero, then the active highlighter
  // transitions in (the ::after square already animates via CSS) once the
  // section reaches the middle band of the viewport. Re-bound per page.
  let projectsSpy: IntersectionObserver | null = null;

  function bindProjectsSpy(currentPath: string, navLinks: NodeListOf<Element>) {
    projectsSpy?.disconnect();
    projectsSpy = null;
    if (currentPath !== "/") return;
    const section = document.getElementById("projects");
    const link = Array.from(navLinks).find((l) => l.getAttribute("href") === "/projects");
    if (!section || !link) return;
    projectsSpy = new IntersectionObserver((entries) => {
      entries.forEach((en) => link.classList.toggle("active", en.isIntersecting));
    }, { rootMargin: "-45% 0px -45% 0px", threshold: 0 });
    projectsSpy.observe(section);
  }

  // Move the active indicator to the link matching `pathname` and clear transient
  // states. Exposed as __dtSyncNav so BarbaTransition can call it DURING the page
  // transition (while the nav is covered) — otherwise the old link stays active for
  // a few ms after the reveal, until init() runs at the very end of the transition.
  function syncActiveNav(pathname?: string) {
    const path = pathname || window.location.pathname;
    // The href that should be active: /projects (incl. project detail pages), the
    // exact path otherwise, or none on home (the logo carries active there).
    const activeHref = path.startsWith('/projects') ? '/projects' : (path === '/' ? null : path);
    // Desktop + mobile nav links both get synced (same hrefs).
    document.querySelectorAll(".nav a, .nav-menu-link").forEach((el) => {
      el.classList.remove("is-clicking", "is-exiting");
      el.classList.toggle("active", activeHref !== null && el.getAttribute("href") === activeHref);
    });
    const headerLogo = document.querySelector(".header-logo");
    headerLogo?.classList.remove("is-clicking", "is-exiting");
    headerLogo?.classList.toggle("active", path === "/");
  }
  (window as any).__dtSyncNav = syncActiveNav;

  function init() {
    // Client-side active state management on page load
    const currentPath = window.location.pathname;
    const navLinks = document.querySelectorAll(".nav a");
    const headerLogo = document.querySelector(".header-logo") as HTMLElement;

    syncActiveNav(currentPath);

    // Make sure the mobile menu is collapsed (and the X folded back) after a navigation.
    document.getElementById("nav-menu-panel")?.classList.remove("is-open");
    const nmBtn = document.getElementById("nav-menu-btn");
    nmBtn?.classList.remove("is-open");
    nmBtn?.setAttribute("aria-expanded", "false");

    bindProjectsSpy(currentPath, navLinks);

    // --- Square Animation Logic ---
    function updateNavScales() {
      navLinks.forEach(link => {
        const width = (link as HTMLElement).offsetWidth;
        if (width > 0) {
          const squareScale = 24.041 / width;
          (link as HTMLElement).style.setProperty('--square-scale', squareScale.toString());
        }
      });
    }

    // Initial calculation
    updateNavScales();
    
    // Only attach event listeners if not already attached (Header is persisted)
    if (!headerLogo.dataset.listenersAttached) {
        // Recalculate on resize
        window.addEventListener('resize', updateNavScales);

        // --- Mobile menu (≤768px): toggle the panel, place it under the trigger ---
        const menuBtn = document.getElementById('nav-menu-btn');
        const menuPanel = document.getElementById('nav-menu-panel');
        const closeMenu = () => {
          menuPanel?.classList.remove('is-open');
          menuBtn?.classList.remove('is-open');       // fold the X back to bars
          menuBtn?.setAttribute('aria-expanded', 'false');
        };
        menuBtn?.addEventListener('click', (e) => {
          e.stopPropagation();
          const open = !menuPanel?.classList.contains('is-open');
          if (open) {
            menuPanel?.classList.add('is-open');
            menuBtn?.classList.add('is-open');         // bars -> X
          } else closeMenu();
          menuBtn?.setAttribute('aria-expanded', String(open));
        });
        document.addEventListener('click', (e) => {
          if (!menuPanel?.classList.contains('is-open')) return;
          const t = e.target as Node;
          if (menuPanel.contains(t) || menuBtn?.contains(t)) return;
          closeMenu();
        });

        // Click Animation with Barba Integration (desktop nav, logo, AND mobile links)
        const allLinks = document.querySelectorAll('.nav a, .header-logo, .nav-menu-link');
        const navContainer = document.querySelector('.nav');

        // Handle hover interactions for exiting state
        if (navContainer) {
          navContainer.addEventListener('mouseenter', (e) => {
             // When hovering over the nav container (which contains links)
             // If there is an active link that is NOT the one being hovered...
             // Wait, mouseenter on nav container is too broad.
             // We want: When hovering ANY link, check if there is another ACTIVE link.
          });
        }

        const NAV_OUT_MS = 400; // must outlast the draw-back wave
        const navLinksList = document.querySelectorAll('.nav a');
        navLinksList.forEach(link => {
            let outTimer: ReturnType<typeof setTimeout> | undefined;
            link.addEventListener('mouseenter', () => {
                // Cancel any in-progress draw-back on the link we're now hovering.
                clearTimeout(outTimer);
                link.classList.remove('is-out');
                // If there is an active link and it's not the one we're hovering, exit it.
                const activeLink = document.querySelector('.nav a.active');
                if (activeLink && activeLink !== link) {
                    activeLink.classList.add('is-exiting');
                }
            });

            link.addEventListener('mouseleave', () => {
                 // Draw this link's fill back out (reverse mosaic wave), then clear the flag.
                 link.classList.add('is-out');
                 outTimer = setTimeout(() => link.classList.remove('is-out'), NAV_OUT_MS);
                 // Restore the active link's resting indicator.
                 const activeLink = document.querySelector('.nav a.active');
                 if (activeLink && activeLink !== link) {
                     activeLink.classList.remove('is-exiting');
                 }
            });
        });

        allLinks.forEach(link => {
          link.addEventListener('click', (e) => {
            e.preventDefault(); // Prevent immediate navigation
            const target = e.currentTarget as HTMLElement;
            const href = target.getAttribute('href');

            closeMenu(); // collapse the mobile menu on any nav click

            // On the home page, PRJT.WORK smooth-scrolls to the embedded
            // #projects section instead of navigating — home and projects
            // behave as one continuous page. The scrollspy lights the link.
            if (href === '/projects' && window.location.pathname === '/') {
              const section = document.getElementById('projects');
              if (section) {
                // Glide there on the home page's unified smooth scroller (a
                // native scrollIntoView would desync its virtual position).
                const glide = (window as any).__dtScrollHome;
                if (glide) glide(section.offsetTop);
                else section.scrollIntoView({ behavior: 'smooth' });
                return;
              }
            }

            // Add clicking class to trigger "scale down from right"
            target.classList.add('is-clicking');

            // Handle exiting animation for the currently active link
            const currentActive = document.querySelector('.nav a.active');
            if (currentActive && currentActive !== target) {
              currentActive.classList.add('is-exiting');
            }
            
            // Wait for animation (0.17s) + small buffer before navigating
            setTimeout(() => {
              // Proceed with Barba navigation
              if (href && (window as any).barba) {
                (window as any).barba.go(href);
              } else if (href) {
                window.location.href = href;
              }
            }, 0);  
          });
        });

        // Mark as attached
        headerLogo.dataset.listenersAttached = "true";
    }
  }

  // Initial load
  init();
  
  // Listen for custom astro:page-load event dispatched by BarbaTransition
  document.addEventListener('astro:page-load', () => {
      init();
  });
</script>
