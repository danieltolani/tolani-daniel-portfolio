---
import MosaicTransition from './MosaicTransition.astro';
---

<MosaicTransition />

<script>
  import barba from '@barba/core';
  import gsap from 'gsap';

  // Dispatch astro:page-load for components like Header that listen for it
  function reinitScripts() {
    document.dispatchEvent(new Event('astro:page-load'));
  }

  // Call the project-page init function if it has been registered and the given
  // container is a project page. This is more reliable than dispatching an event
  // because module scripts compiled by Astro/Vite may not have been evaluated yet
  // when the event fires after a Barba navigation. Scoped to the container so a
  // leaving project page (still in the DOM mid-transition) can't trigger it.
  // True once initAll has actually run for the current page cycle, so the late
  // asset-loaded fallback (below) doesn't double-init when enter() already did.
  let projectInitDone = false;
  function callProjectInit(container: HTMLElement) {
    if (container.getAttribute('data-barba-namespace') !== 'project') return;
    if (projectInitDone) return; // already initialized this page cycle — no double-init
    if (typeof (window as any).__dtProjectInit === 'function') {
      (window as any).__dtProjectInit();
      projectInitDone = true;
    } else {
      console.warn('[barba] project page but __dtProjectInit not ready — interactions skipped');
    }
  }

  // Hard ceiling on how long the red tile cover may wait for the next page's
  // CSS/JS before revealing anyway. On a slow network a heavy chunk used to hang
  // the reveal indefinitely (stuck red screen); past this cap we show the text and
  // layout that ARE ready — images keep their own per-image red cover until loaded,
  // and interactions wire up via the late-load fallback once the scripts arrive.
  const ASSET_WAIT_CAP_MS = 1500;

  // Signals "the page content is about to become visible" — fired when the load
  // intro starts (after the enter click) and on every Barba enter. Page scripts
  // (e.g. the home hero line reveal) listen for this to start entrance effects.
  // detail.delay is how long until the content actually starts appearing (ms).
  function dispatchContentEnter(delay = 0) {
    document.dispatchEvent(new CustomEvent('dt:content-enter', { detail: { delay } }));
  }

  // Signals "the transition tiles have fully cleared — the page is on screen".
  // Effects that must be SEEN (e.g. the carousel red-tile covers) hold until this.
  function dispatchPageVisible() {
    pageVisibleResolve?.();
    pageVisibleResolve = null;
    document.dispatchEvent(new CustomEvent('dt:page-visible'));
  }

  // Signals "a Barba navigation is starting" (the tiles begin covering the
  // screen). Used to duck the background music during the transition.
  function dispatchPageLeave() {
    document.dispatchEvent(new CustomEvent('dt:page-leave'));
  }

  // ── Site-wide mosaic image covers ──────────────────────────────────────────
  // Every <img> in the entering container is covered solid red while the page
  // is hidden. Once BOTH the page is on screen AND the image has fully loaded,
  // the cover breaks into tiles and waves out top-right -> bottom-left. A slow
  // image (network) simply stays red until it's ready — nothing on the site
  // ever shows a half-loaded image.
  const IMG_TILE_RED   = '#f72f2f';
  const IMG_TILE_WHITE = '#E5EAF4'; // secondary used by the page transition tiles
  const IMG_TILE_SIZE  = 28;     // approx px per tile
  const IMG_WAVE_STEP  = 0.018;  // s per diagonal step
  const IMG_SCATTER    = 0.07;   // s of per-tile randomness on the wave front
  const IMG_EARLY_ODDS = 0.05;   // fraction of "scout" tiles that pop ahead of the front
  const IMG_WHITE_LEAD = 0.05;   // s a tile shows white before it exits (data-cover-white)
  const IMG_WHITE_ODDS = 0.18;   // fraction of tiles that get the white flash

  // Gate armed at the start of each page cycle, opened by dispatchPageVisible().
  let pageVisibleResolve: (() => void) | null = null;
  let pageVisiblePromise: Promise<void> = Promise.resolve();
  function armPageVisibleGate() {
    pageVisiblePromise = new Promise((res) => { pageVisibleResolve = res; });
  }

  // Resolves when the image is loaded AND decoded — decode() pre-rasterizes the
  // bitmap while it's still covered, so the reveal doesn't jank on first paint.
  function imageReady(img: HTMLImageElement): Promise<void> {
    const decoded = () => (img.decode ? img.decode().catch(() => {}) : Promise.resolve());
    if (img.complete && img.naturalWidth > 0) return decoded();
    return new Promise((res) => {
      img.addEventListener('load',  () => { decoded().then(res); }, { once: true });
      img.addEventListener('error', () => res(), { once: true }); // never stuck red
    });
  }

  function coverImages(container: HTMLElement) {
    container.querySelectorAll('img').forEach((img) => {
      // Carousel cards run their own cover + slide-in choreography.
      if (img.closest('.carousel-item-inner')) return;

      const parent = img.parentElement;
      if (!parent) return;
      if (getComputedStyle(parent).position === 'static') parent.style.position = 'relative';

      // Solid red while waiting — tiles are only built at reveal time, sized to
      // the image's FINAL box (it may have had no dimensions before loading).
      const overlay = document.createElement('div');
      overlay.style.cssText =
        `position:absolute;background:${IMG_TILE_RED};pointer-events:none;` +
        'z-index:4;display:grid;border-radius:inherit;overflow:hidden;';
      const place = () => {
        overlay.style.left   = img.offsetLeft + 'px';
        overlay.style.top    = img.offsetTop + 'px';
        overlay.style.width  = img.offsetWidth + 'px';
        overlay.style.height = img.offsetHeight + 'px';
      };
      place();
      parent.appendChild(overlay);
      const visibleGate = pageVisiblePromise; // this page cycle's gate

      // Build the tile grid as soon as the image is ready (visually identical to
      // the solid red, and it happens while the page is still covered) so the
      // reveal moment only schedules tweens — no DOM-construction spike that
      // would stall the carousel slide-in.
      imageReady(img).then(() => {
        place();
        const w = overlay.offsetWidth, h = overlay.offsetHeight;
        if (!w || !h) { overlay.remove(); return; }
        const cols = Math.min(24, Math.max(3, Math.round(w / IMG_TILE_SIZE)));
        const rows = Math.min(18, Math.max(3, Math.round(h / IMG_TILE_SIZE)));
        overlay.style.gridTemplateColumns = `repeat(${cols},1fr)`;
        overlay.style.gridTemplateRows = `repeat(${rows},1fr)`;
        overlay.style.background = 'transparent';
        const tiles: HTMLDivElement[] = [];
        for (let i = 0; i < cols * rows; i++) {
          const tile = document.createElement('div');
          tile.style.backgroundColor = IMG_TILE_RED;
          overlay.appendChild(tile);
          tiles.push(tile);
        }

        visibleGate.then(() => {
          // Default wave: top-right -> bottom-left. data-cover-dir overrides:
          // "ltr" sweeps left -> right, "tl-br" sweeps diagonally top-left ->
          // bottom-right (the home hero image — matches its text direction).
          // With data-cover-white, some tiles flip to the off-white just before
          // exiting, so white sparks overlap between the red front and the image.
          const dir = img.dataset.coverDir || '';
          const whiteLead = img.dataset.coverWhite !== undefined ? IMG_WHITE_LEAD : 0;
          const base = 0.05 + Math.random() * 0.1; // tiny jitter between images
          let maxDelay = 0;
          tiles.forEach((tile, i) => {
            const r = Math.floor(i / cols);
            const c = i % cols;
            const order =
              dir === 'ltr'   ? c :
              dir === 'tl-br' ? c + r :
              (cols - 1 - c) + r;
            const wave = order * IMG_WAVE_STEP;
            let d = base + wave + Math.random() * IMG_SCATTER;
            // A few scout tiles blink out ahead of the front for an organic seed.
            if (Math.random() < IMG_EARLY_ODDS) d = base + Math.random() * wave;
            maxDelay = Math.max(maxDelay, d);
            // Sparse flash: only some tiles blink white, right before they exit.
            if (whiteLead && Math.random() < IMG_WHITE_ODDS) {
              gsap.set(tile, { backgroundColor: IMG_TILE_WHITE, delay: Math.max(0, d - whiteLead) });
            }
            gsap.set(tile, { autoAlpha: 0, delay: d });
          });
          gsap.delayedCall(maxDelay + 0.1, () => overlay.remove());
        });
      });
    });
  }

  // Identity key = pathname + query, ignoring only the HMR cache-bust (?v=) and
  // our own ?__reinit=. Pathname alone is too loose in dev: it conflates a file's
  // ?type=script with its ?type=style, and index=0 with index=1.
  const scriptKeyOf = (u: string) => {
    try {
      const url = new URL(u, window.location.href);
      const p = url.searchParams;
      p.delete('v'); p.delete('__reinit');
      const q = Array.from(p.entries()).sort().map(([k, val]) => `${k}=${val}`).join('&');
      return url.pathname + (q ? `?${q}` : '');
    } catch { return u; }
  };

  // Keys of scripts that have actually EXECUTED. We must track this ourselves
  // instead of scanning the DOM: Astro renders page scripts inside the barba
  // container, and Barba inserts the next container into the DOM *before*
  // beforeEnter runs — script tags that arrive that way never execute, so a DOM
  // scan wrongly counts them as loaded and the page's JS never runs.
  const executedScriptKeys = new Set(
    Array.from(document.querySelectorAll('script[src]'))
      .map((s) => scriptKeyOf((s as HTMLScriptElement).src))
  );

  // iOS Sheet-style entrance, staggered by row (top rows land first). 500ms
  // (intentionally over the 300ms guideline) with the iOS sheet presentation bezier.
  // Used on both initial load (once) and navigation (enter). Returns total ms.
  // Easing curves: page-to-page (with the tile reveal) uses the iOS sheet curve;
  // initial load/refresh uses a no-pause curve (instant start) since there's no
  // tile cover to mask the slow ramp-in.
  const SHEET_EASE = 'cubic-bezier(0.32, 0.72, 0, 1)';  // page-to-page sheet curve

  // Load/refresh "boom": content stays hidden (just the dark bg shows) until the red
  // tile exit is ~50% done, then the whole page appears in one quick move.
  const LOAD_ENTER_EASE  = 'cubic-bezier(0.22, 1, 0.36, 1)'; // easeOutQuint — energized, no overshoot
  const LOAD_REVEAL_MS   = 813;  // keep in sync with MosaicTransition LOAD_REVEAL_DURATION
  const LOAD_ENTER_MS    = 800;
  const LOAD_ENTER_DELAY = Math.round(LOAD_REVEAL_MS * 0.6); // ~half cleared (ease-in exit)
  const LOAD_STAGGER_STEP = 55;  // ms between rows on the load boom

  const SHEET_OFFSET = () => Math.round(window.innerHeight * 0.10); // ~10% of viewport
  const LOAD_OFFSET  = () => Math.round(window.innerHeight * 0.14); // bigger travel = more energy
  const ROW_TOLERANCE = 8;       // px; elements within this share a visual row
  const ENTER_EXCLUDE = '.hero-availability-wrapper'; // never animated (stays static)

  // Collect content rows top -> bottom with a stagger bucket per visual row. Flattens
  // one level into a wrapper's children (so a full-bleed bg wrapper like .hero-page
  // stays put while its inner blocks animate); otherwise the direct child is a row.
  function collectRows(next: HTMLElement): { rows: { el: HTMLElement; bucket: number }[]; maxRow: number } {
    const targets: HTMLElement[] = [];
    Array.from(next.children).forEach((child) => {
      if (!(child instanceof HTMLElement)) return;
      const inner = Array.from(child.children).filter((g) => g instanceof HTMLElement) as HTMLElement[];
      if (inner.length >= 2) targets.push(...inner);
      else targets.push(child);
    });
    const filtered = targets.filter((el) => !el.matches(ENTER_EXCLUDE));
    const els = filtered.length ? filtered : [next];
    els.sort((a, b) => a.getBoundingClientRect().top - b.getBoundingClientRect().top);

    const rows: { el: HTMLElement; bucket: number }[] = [];
    let rowIndex = -1, lastTop = -Infinity;
    for (const el of els) {
      const top = el.getBoundingClientRect().top;
      if (top - lastTop > ROW_TOLERANCE) { rowIndex++; lastTop = top; }
      rows.push({ el, bucket: rowIndex });
    }
    return { rows, maxRow: rowIndex };
  }

  // Project pages run their own intricate intro + ScrollTrigger animations. A
  // transform on the container/sections mismeasures those triggers (the hero gets
  // pinned to opacity 0), so we skip the transform entrance there and just reveal.
  function isProject(next: HTMLElement): boolean {
    return next.getAttribute('data-barba-namespace') === 'project';
  }

  // Page-to-page entrance: rows slide up into rest, staggered.
  // dir 'down' = top rows first; 'up' = bottom rows first.
  function staggerEnter(next: HTMLElement, ease: string = SHEET_EASE, dir: 'down' | 'up' = 'down'): number {
    next.style.opacity = '1';
    const offset = SHEET_OFFSET();
    const STAGGER_STEP = 70;
    const { rows, maxRow } = collectRows(next);
    for (const { el, bucket } of rows) {
      const order = dir === 'up' ? (maxRow - bucket) : bucket;
      el.animate(
        [{ transform: `translateY(${offset}px)` }, { transform: 'translateY(0)' }],
        { duration: 500, easing: ease, delay: order * STAGGER_STEP, fill: 'backwards' }
      );
    }
    return 500 + (maxRow + 1) * STAGGER_STEP;
  }

  // Load/refresh entrance: rows stay hidden (just the dark bg shows) until the red
  // tile exit is ~50% done, then boom up into rest, staggered top-first so the pull
  // reads as coming from the top.
  function loadEntrance(next: HTMLElement) {
    next.style.opacity = '1';
    const offset = LOAD_OFFSET();
    const { rows } = collectRows(next);
    for (const { el, bucket } of rows) {
      const order = bucket; // top-first
      el.animate(
        [
          { opacity: 0, transform: `translateY(${offset}px)` },
          { opacity: 1, transform: 'translateY(0)' }
        ],
        {
          duration: LOAD_ENTER_MS,
          easing: LOAD_ENTER_EASE,
          delay: LOAD_ENTER_DELAY + order * LOAD_STAGGER_STEP,
          fill: 'backwards'
        }
      );
    }
  }

  barba.init({
    preventRunning: true,
    debug: true,
    transitions: [{
      name: 'default-transition',

      once(data: any) {
        // Initial page load / refresh — module scripts have all evaluated by now.
        const next = data.next.container as HTMLElement;
        armPageVisibleGate();
        callProjectInit(next);
        coverImages(next);
        reinitScripts();
        // Hold on the red screen until the user clicks "Enter with sound" — that
        // gesture unlocks audio, then we exit the red tiles (with sound) and boom
        // the content in.
        const startIntro = () => {
          // loadIntro() resolves when the red tiles have fully cleared.
          const intro = (window as any).blockTransition?.loadIntro
            ? (window as any).blockTransition.loadIntro()
            : null;
          Promise.resolve(intro).then(() => dispatchPageVisible());
          // Project pages: reveal without the transform entrance (keeps ScrollTrigger sane).
          if (isProject(next)) {
            next.style.opacity = '1';
            dispatchContentEnter(0);
          } else {
            loadEntrance(next);
            dispatchContentEnter(LOAD_ENTER_DELAY);
          }
        };
        // Either gate button reveals the site. "Enter with sound" starts audio;
        // the silent "enter" leaves it muted (handled in BackgroundMusic). Both just
        // hide the buttons and run the same intro here.
        const enterBtn = document.getElementById('mosaic-enter-btn');
        const enterSilentBtn = document.getElementById('mosaic-enter-silent-btn');
        let entered = false;
        const revealOnce = () => {
          if (entered) return;
          entered = true;
          if (enterBtn) enterBtn.style.display = 'none';
          if (enterSilentBtn) enterSilentBtn.style.display = 'none';
          startIntro();
        };
        if (enterBtn || enterSilentBtn) {
          enterBtn?.addEventListener('click', revealOnce);
          enterSilentBtn?.addEventListener('click', revealOnce);
        } else {
          startIntro(); // no button (e.g. no-JS path shouldn't reach here) — just run
        }
      },

      async beforeEnter(data: any) {
        projectInitDone = false; // reset for this navigation cycle
        const parser = new DOMParser();
        const nextDoc = parser.parseFromString(data.next.html, 'text/html');

        // ── CSS: inject any link/style tags the next page needs ──────────────
        // Awaited so layout is fully styled before enter() measures it.
        const loads: Promise<void>[] = [];
        const currentHrefs = new Set(
          Array.from(document.querySelectorAll('link[rel="stylesheet"]'))
            .map(l => (l as HTMLLinkElement).href)
        );
        nextDoc.querySelectorAll('link[rel="stylesheet"]').forEach(link => {
          if (!currentHrefs.has((link as HTMLLinkElement).href)) {
            const el = link.cloneNode(true) as HTMLLinkElement;
            loads.push(new Promise<void>((resolve) => {
              el.onload  = () => resolve();
              el.onerror = () => resolve();
            }));
            document.head.appendChild(el);
          }
        });

        const currentStyleContents = new Set(
          Array.from(document.querySelectorAll('style')).map(s => s.innerHTML)
        );
        nextDoc.querySelectorAll('style').forEach(style => {
          if (!currentStyleContents.has(style.innerHTML)) {
            document.head.appendChild(style.cloneNode(true));
          }
        });

        // ── JS: load any scripts the next page has that haven't executed yet ──
        nextDoc.querySelectorAll('script[src]').forEach((scriptEl) => {
          const rawSrc = scriptEl.getAttribute('src');
          if (!rawSrc) return;

          let key: string;
          try {
            key = scriptKeyOf(new URL(rawSrc, window.location.href).href);
          } catch { return; }

          if (executedScriptKeys.has(key)) return;
          executedScriptKeys.add(key);

          loads.push(new Promise<void>((resolve) => {
            const el = document.createElement('script');
            const type = scriptEl.getAttribute('type');
            if (type) el.type = type;
            el.src = rawSrc;           // browser resolves relative to current page
            el.onload  = () => resolve();
            el.onerror = () => resolve();
            document.head.appendChild(el);
          }));
        });

        // On a fast connection Promise.all resolves first and everything is styled
        // + interactive before the reveal (unchanged happy path). On a slow one the
        // cap wins and we stop blocking the red cover — but the page may reveal
        // before its scripts ran, so once they finally load, wire up interactions
        // (if enter() couldn't) rather than leaving a project page dead.
        if (loads.length) {
          const allLoaded = Promise.all(loads);
          allLoaded.then(() => {
            if (!projectInitDone) callProjectInit(data.next.container as HTMLElement);
          });
          await Promise.race([
            allLoaded,
            new Promise<void>((res) => setTimeout(res, ASSET_WAIT_CAP_MS)),
          ]);
        }

        // ── Title ─────────────────────────────────────────────────────────────
        const newTitle = nextDoc.querySelector('title');
        if (newTitle) document.title = newTitle.innerText;
      },

      async leave(data: any) {
        const done = (this as any).async();
        dispatchPageLeave();
        if ((window as any).blockTransition) {
          await (window as any).blockTransition.enter();
        } else {
          await gsap.to(data.current.container, { opacity: 0, duration: 0.5 });
        }
        gsap.set(data.current.container, { display: 'none' });
        done();
      },

      async enter(data: any) {
        const next = data.next.container as HTMLElement;

        // Reset scroll and init the page's interactions BEFORE the tile reveal:
        // carousels and ScrollTrigger are then already running while the tiles
        // clear, so the page is in motion the instant it becomes visible (no
        // frozen-then-jerk start). The container has been in the DOM and styled
        // since beforeEnter, so measurements are valid here.
        window.scrollTo(0, 0);
        // html,body{height:100%;overflow-x:hidden} makes the BODY the actual
        // scrolling element — window.scrollTo alone resets nothing, and a stale
        // body scroll displaces every ScrollTrigger/Smooothy measurement below.
        document.documentElement.scrollTop = 0;
        document.body.scrollTop = 0;
        const sc = next.matches('.scroll-container')
          ? next : next.querySelector('.scroll-container') as HTMLElement | null;
        if (sc) sc.scrollTop = 0;
        armPageVisibleGate();
        callProjectInit(next);
        coverImages(next);
        dispatchContentEnter(0);

        gsap.set(next, { opacity: 1, display: 'block' });

        // Staggered row entrance, concurrently with the red reveal — but skip the
        // transform on project pages so it doesn't break their ScrollTrigger setup.
        const entranceMs = isProject(next) ? 0 : staggerEnter(next);

        if ((window as any).blockTransition) {
          await (window as any).blockTransition.leave();
        } else {
          await new Promise((res) => setTimeout(res, entranceMs));
        }
      },

      after(_data: any) {
        // Dispatch astro:page-load for listeners like Header.
        reinitScripts();
        // enter() resolved, so the tile reveal has finished — page is on screen.
        dispatchPageVisible();
      }
    }],

    views: [
      { namespace: 'default', beforeEnter() {} },
      { namespace: 'project', afterEnter() {} }
    ],

    prevent: ({ el }: any) => el.hasAttribute('data-barba-prevent')
  });

  (window as any).barba = barba;
</script>
