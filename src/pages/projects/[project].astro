                          class={`sketch-image ${img.src === "/GIF/farmove-pointer-ariel-loop.gif" ? "pointer-ariel-image" : ""} ${img.src === "/GIF/farmove-arrow-loop-wide.gif" ? "arrow-loop-image" : ""}`}
                        />
