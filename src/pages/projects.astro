---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import ProjectsExperience from "../components/ProjectsExperience.astro";
import data from "../data/projects/index";
import "../styles/portfolio.css";

const projects = data;
const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME;

// Helper to determine media type and src (no-JS fallback preview)
const getMediaInfo = (project: any) => {
  const src = project["preview-media"]?.src || "";
  if (!src) return { type: "image", url: "" };
  if (src.startsWith("/")) return { type: "image", url: src };
  return {
    type: "video",
    url: `https://res.cloudinary.com/${cloudName}/video/upload/f_auto,q_auto/${src}.mp4`,
  };
};

const firstProjectMedia = getMediaInfo(projects[0]);
---

<Layout title="Projects | Portfolio">
  <div class="page-container projects-fly-page">

    <!-- Full experience (shared with the home page's #projects section) -->
    <ProjectsExperience />

    <!-- ════ NO-JS FALLBACK: plain list ════ -->
    <main class="projects-overview-section projects-fallback">
      <div class="projects-overview-container">
        <div class="projects-list">
          {projects.map((project, index) => (
            <div class={`project-list-item ${index === 0 ? "active" : ""}`}>
              <div class="project-item-header">
                <span class="project-number">{(index + 1).toString().padStart(2, "0")}</span>
                <a href={`/projects/${project.project}`} class="project-name-link">
                  <h2 class="project-name" set:html={project.title}></h2>
                </a>
              </div>
              <a href={`/projects/${project.project}`} class="project-link-btn">
                view case study
                <span class="arrow-icon">
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M1 11L11 1M11 1H3M11 1V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </a>
            </div>
          ))}
        </div>

        <div class="project-preview-column">
          <div class="project-preview-sticky">
            <div class="preview-media-wrapper">
              {firstProjectMedia.type === "video" ? (
                <video src={firstProjectMedia.url} class="preview-media-element" autoplay loop muted playsinline></video>
              ) : (
                <img src={firstProjectMedia.url} alt="Project Preview" class="preview-media-element" />
              )}
            </div>
            <div class="preview-info">
              <h3 class="preview-title" set:html={projects[0]?.title || ""}></h3>
              <p class="preview-description">{projects[0]?.description1}</p>
            </div>
          </div>
        </div>
      </div>

      <Footer />
    </main>
  </div>
</Layout>

<style is:global>
  /* JS on: show the experience, hide the fallback. JS off: the reverse. */
  html.js-enter .projects-fallback { display: none; }

  .projects-fly-page {
    height: 100vh;
    overflow: hidden;
    background: #141417;
  }
</style>
