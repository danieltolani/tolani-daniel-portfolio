---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import AvailabilityTime from '../components/AvailabilityTime.astro';
import ProjectsExperience from '../components/ProjectsExperience.astro';
import SpaceDots from '../components/SpaceDots.astro';
import '../styles/hero.css';
import '../styles/header.css';
import '../styles/footer.css';
---

<Layout>
  
  <main class="hero-page">
    <!-- 3D drifting dot field filling the black space above the hero image. -->
    <SpaceDots height="72vh" />

    <div class="hero-availability-wrapper">
      <AvailabilityTime />
    </div>

    <section class="hero-content">
      <div class="hero-text-row">
        <h1 class="hero-title">
          moti<span class="pixel-font">o</span>n an<span class="pixel-font">d</span><br>
          IN<span class="pixel-font">T</span>E<span class="pixel-font">R</span>A<span class="pixel-font">C</span>TION<br>
          <span class="pixel-font">d</span>e<span class="pixel-font">s</span>ign<span class="pixel-font">e</span>r.
        </h1>
        <p class="hero-subtitle">
          using aRTISTIC shapes, colors, texts AND sound in a way that they <span class="red-text">MOVE to COMMUNICATE.</span>
        </p>

        <!-- Showreel slot — empty container for now, video drops in later. -->
        <div class="hero-reel" id="hero-reel" aria-label="Showreel">
          <span class="hero-reel-label">REEL</span>
          <span class="hero-reel-accent"></span>
        </div>
      </div>
    </section>

    <div class="hero-image-container">
      <img src="/png/hero-image.png" alt="Hero composition" class="hero-image" data-cover-dir="tl-br" data-cover-white />
    </div>
  </main>

  <!-- ════ PROJECTS SECTION (id-navigable) ════
       The FULL projects experience (space/stack/list + switcher), embedded as
       a section under the hero image — same component as /projects, so home
       and projects feel like one continuous page. Its wheel handling releases
       to normal page scroll at the boundaries. The header's PRJT.WORK
       highlighter transitions in via scrollspy (Header.astro). -->
  <section class="home-projects-xp" id="projects">
    <ProjectsExperience embedded />
  </section>

  <Footer />
</Layout>

<script>
  import { gsap } from "gsap";
  import { SplitText } from "gsap/SplitText";

  gsap.registerPlugin(SplitText);

  // Mosaic-themed line reveal for the hero text: each visual line gets covered by
  // a red tile-bar sweeping in from the left; the bar then exits to the right with
  // an ease-in, revealing the text underneath. Staggered line by line. Runs on
  // dt:content-enter, which BarbaTransition fires whenever the page content starts
  // to appear (initial load intro and every Barba navigation).
  const TILE_RED = "#f72f2f";
  const LINE_STAGGER = 0.055;
  const COVER_IN_S = 0.18;
  const COVER_OUT_S = 0.28;
  const COVER_HOLD_S = 0.02; // beat between full cover and the exit
  // Settle matches the load entrance's "spike": same easeOutQuint, same 800ms,
  // with a big sideways displacement (~6vw) so the first frames whip into place.
  const SETTLE_X = () => Math.round(window.innerWidth * 0.06);
  const SETTLE_S = 0.8;      // = LOAD_ENTER_MS in BarbaTransition
  const POSTERIZE_FPS = 12;

  // After Effects posterizeTime(12) feel: quantize the eased progress to 12fps
  // frames, so the settle steps like stop-motion instead of gliding.
  const settleEase = (() => {
    const base = gsap.parseEase("power4.out"); // easeOutQuint, same as drag-up
    const frames = Math.max(1, Math.round(SETTLE_S * POSTERIZE_FPS));
    return (t: number) => base(Math.floor(t * frames) / frames);
  })();

  let running = false;

  async function runHeroLineReveal(delayMs: number) {
    const hero = document.querySelector(".hero-page");
    if (!hero || running) return;
    const targets = [".hero-title", ".hero-subtitle"]
      .map((s) => hero.querySelector(s))
      .filter((el): el is HTMLElement => el instanceof HTMLElement);
    if (!targets.length) return;
    running = true;

    // Hide the text right away (the container isn't visible yet, so no flash),
    // then split once fonts are ready so line breaks measure the real typeface.
    targets.forEach((t) => (t.style.visibility = "hidden"));
    await document.fonts.ready;

    const split = SplitText.create(targets, {
      type: "lines",
      linesClass: "hero-reveal-line",
    });
    targets.forEach((t) => (t.style.visibility = ""));

    const lines = split.lines as HTMLElement[];
    const bars = lines.map((line) => {
      line.style.position = "relative";
      line.style.visibility = "hidden"; // children can override visibility,
      line.style.transform = `translateX(${-SETTLE_X()}px)`; // displaced; settles in
      const bar = document.createElement("div"); // so the bar stays visible
      bar.style.cssText =
        `position:absolute;inset:0;background:${TILE_RED};` +
        "transform:scaleX(0);transform-origin:left center;" +
        "visibility:visible;pointer-events:none;";
      line.appendChild(bar);
      return bar;
    });

    const tl = gsap.timeline({
      delay: delayMs / 1000,
      onComplete: () => {
        bars.forEach((b) => b.remove());
        // Do NOT revert here: natural text re-wraps slightly differently than
        // SplitText's measured lines, so reverting makes the block jump (the
        // row is bottom-aligned, so a height change shifts everything). Keep
        // the split DOM; revert only on resize, where reflow is wanted anyway.
        const revertOnResize = () => {
          window.removeEventListener("resize", revertOnResize);
          split.revert();
        };
        window.addEventListener("resize", revertOnResize, { once: true });
        running = false;
      },
    });
    lines.forEach((line, i) => {
      const at = i * LINE_STAGGER;
      // Sweep in covering the (hidden, displaced) line, pop the text in at full
      // cover, then exit right with an ease-in while the line settles into place.
      tl.to(bars[i], { scaleX: 1, duration: COVER_IN_S, ease: "power3.out" }, at)
        .set(line, { visibility: "visible" }, at + COVER_IN_S)
        .set(bars[i], { transformOrigin: "right center" }, at + COVER_IN_S)
        .to(bars[i], { scaleX: 0, duration: COVER_OUT_S, ease: "power2.in" }, at + COVER_IN_S + COVER_HOLD_S)
        // Settle is an entrance: same easeOutQuint + 800ms as the rows' drag-up
        // (LOAD_ENTER_EASE/LOAD_ENTER_MS), posterized to 12fps; bar exit stays ease-in.
        .to(line, { x: 0, duration: SETTLE_S, ease: settleEase }, at + COVER_IN_S + COVER_HOLD_S);
    });
  }

  // The hero IMAGE itself is displaced left and settles into rest just like the
  // text lines. Its red mosaic cover stays put (the displaced edge is clipped by
  // the container's overflow:hidden), and the settle starts at the same moment
  // the cover begins waving out — page visible AND image loaded — so the slide
  // into position is actually seen through the dissolving tiles.
  function runHeroImageSettle() {
    const img = document.querySelector(".hero-page .hero-image");
    if (!(img instanceof HTMLImageElement)) return;
    const settle = () => {
      gsap.fromTo(
        img,
        { x: -SETTLE_X() },
        { x: 0, duration: SETTLE_S, ease: settleEase, clearProps: "transform" }
      );
    };
    if (img.complete && img.naturalWidth > 0) settle();
    else {
      img.addEventListener("load", settle, { once: true });
      img.addEventListener("error", settle, { once: true });
    }
  }

  document.addEventListener("dt:content-enter", (e) => {
    runHeroLineReveal((e as CustomEvent).detail?.delay ?? 0);
  });
  document.addEventListener("dt:page-visible", () => runHeroImageSettle());

  // ════ UNIFIED HOME SMOOTH SCROLL ════
  // One lerped virtual timeline drives the entire home page: body scroll down
  // to the projects section, then the experience's internal progress (tunnel /
  // stack / list, via its __flyApi), then body scroll again to the footer.
  // Entering, flying through and leaving the section are a single continuous
  // eased motion — there is no handoff, so there is nothing to hiccup.
  // Also feeds the fixed SCRL readout (how far until the bottom of the page).
  const HOME_SCROLL = {
    lerp: 0.1,        // page glide weight
    touchMult: 2.2,
  };

  function initHomeScroll() {
    const heroPage = document.querySelector<HTMLElement>(".hero-page");
    const section = document.getElementById("projects");
    const xpRoot = section?.querySelector(".projects-experience");
    if (!heroPage || !section || !xpRoot || heroPage.dataset.scrollBound) return;
    heroPage.dataset.scrollBound = "true";
    // Tell the generic SCRL updater (BackgroundMusic) to stand down — home drives
    // the readout from its virtual fly-through scroll while it's mounted.
    (window as any).__dtHomeScrollActive = true;

    // Progress readout sits in the persistent corner HUD (#dt-corner), to the
    // RIGHT of the sound toggle. Falls back to <body> if the HUD isn't present.
    // It lives outside the barba container either way, so the page entrance
    // row-animations never transform it; removed on page leave.
    let hud = document.querySelector<HTMLElement>(".scroll-progress");
    if (!hud) {
      hud = document.createElement("div");
      hud.className = "scroll-progress fly-mono";
      hud.innerHTML = "SCRL <b>000%</b>";
      (document.getElementById("dt-corner") || document.body).appendChild(hud);
    }
    const hudVal = hud.querySelector("b");

    const sc = { target: document.body.scrollTop, current: document.body.scrollTop };

    const onWheel = (e: WheelEvent) => {
      if (!heroPage!.isConnected) return;
      e.preventDefault();
      sc.target += e.deltaY;
    };
    window.addEventListener("wheel", onWheel, { passive: false });

    let touchY = 0;
    const onTouchStart = (e: TouchEvent) => { touchY = e.touches[0].clientY; };
    const onTouchMove = (e: TouchEvent) => {
      if (!heroPage!.isConnected) return;
      e.preventDefault();
      const y = e.touches[0].clientY;
      sc.target += (touchY - y) * HOME_SCROLL.touchMult;
      touchY = y;
    };
    window.addEventListener("touchstart", onTouchStart, { passive: true });
    window.addEventListener("touchmove", onTouchMove, { passive: false });

    // Header's PRJT.WORK uses this for its smooth scroll into the section.
    (window as any).__dtScrollHome = (y: number) => { sc.target = y; };

    // Reel choreography targets. The hero reel is scrubbed (dips away with
    // scroll); the footer reel is TRIGGERED — a real timed ease-out entrance
    // when you arrive at the bottom, independent of scroll speed.
    const heroReel = document.querySelector<HTMLElement>(".hero-reel");
    const footerReel = document.querySelector<HTMLElement>(".footer-reel");
    let footerReelShown = false;
    if (footerReel) gsap.set(footerReel, { y: -240, autoAlpha: 0 });

    let frame = 0;
    let prevLen = -1;
    function raf() {
      if (!heroPage!.isConnected) {
        // Page left — release everything this scroller owns.
        window.removeEventListener("wheel", onWheel);
        window.removeEventListener("touchstart", onTouchStart);
        window.removeEventListener("touchmove", onTouchMove);
        delete (window as any).__dtScrollHome;
        // Hand the (persistent) SCRL readout back to the generic updater.
        (window as any).__dtHomeScrollActive = false;
        return;
      }

      const S = section!.offsetTop;                       // section flush point
      const api = (xpRoot as any).__flyApi;
      const len = api ? api.getLength() : 0;              // current view's travel
      const R = Math.max(0, document.body.scrollHeight - window.innerHeight - S);
      const total = S + len + R;

      // View switches change the section's travel length — remap the virtual
      // position so the page stays EXACTLY where it is (no jump): in-section
      // progress clamps to the new length, footer positions shift with it.
      if (prevLen >= 0 && len !== prevLen) {
        const remap = (v: number) =>
          v <= S ? v : v <= S + prevLen ? S + Math.min(v - S, len) : v - prevLen + len;
        sc.current = remap(sc.current);
        sc.target = remap(sc.target);
      }
      prevLen = len;

      sc.target = Math.max(0, Math.min(total, sc.target));
      sc.current += (sc.target - sc.current) * HOME_SCROLL.lerp;
      if (Math.abs(sc.target - sc.current) < 0.05) sc.current = sc.target;

      if (sc.current <= S) {
        document.body.scrollTop = sc.current;
        api?.setProgress(0);
      } else if (sc.current <= S + len) {
        document.body.scrollTop = S;
        api?.setProgress(sc.current - S);
      } else {
        document.body.scrollTop = S + (sc.current - S - len);
        api?.setProgress(len);
      }

      // Reel choreography: scrolling away from the hero dips the reel down
      // behind the hero image and hides it; approaching the very bottom eases
      // it (quint-out) into its footer slot beside WTH / AS OF TODAY.
      if (heroReel) {
        const hideP = Math.min(1, sc.current / (window.innerHeight * 0.45));
        heroReel.style.transform = `translateY(${Math.round(hideP * 150)}px)`;
        heroReel.style.opacity = (1 - hideP).toFixed(3);
      }
      if (footerReel) {
        // Trigger on the reel's ACTUAL viewport entry (not the virtual scroll
        // value, which crosses "near bottom" long before the glide visually
        // arrives — the tween would finish off-screen and look pre-placed).
        const rr = footerReel.getBoundingClientRect();
        if (!footerReelShown && rr.top < window.innerHeight * 0.96) {
          footerReelShown = true;
          // Timed entrance: drops in from above with the house easeOutQuint,
          // the same regardless of how fast the scroll arrived.
          // Big travel from well above, after a beat — the drop has to clearly
          // outrun the page's own upward glide or the two motions cancel and
          // it reads as already-placed.
          gsap.fromTo(footerReel,
            { y: -240, autoAlpha: 0 },
            { y: 0, autoAlpha: 1, duration: 1.05, ease: "power4.out", delay: 0.18, overwrite: "auto" }
          );
        } else if (footerReelShown && rr.top > window.innerHeight * 1.25) {
          // Re-arm once the slot is well below the viewport again.
          footerReelShown = false;
          gsap.set(footerReel, { y: -240, autoAlpha: 0 });
        }
      }

      if (++frame % 5 === 0 && hudVal) {
        const pct = total > 0 ? Math.round((sc.current / total) * 100) : 0;
        hudVal.textContent = `${String(Math.max(0, Math.min(100, pct))).padStart(3, "0")}%`;
      }

      requestAnimationFrame(raf);
    }
    requestAnimationFrame(raf);
  }

  initHomeScroll();
  document.addEventListener("astro:page-load", initHomeScroll);
</script>

